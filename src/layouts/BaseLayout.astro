---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const currentPath = Astro.url.pathname;
const site = 'https://adityasharma.cc';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/resume/', label: 'Resume' },
  { href: '/experience/', label: 'Experience' },
  { href: '/contact/', label: 'Contact' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical || `${site}${currentPath}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${site}${currentPath}`} />
    <meta property="og:site_name" content="Aditya Sharma" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Aditya Sharma",
      "jobTitle": "Software Engineer",
      "worksFor": [
        { "@type": "Organization", "name": "Microsoft" },
        { "@type": "Organization", "name": "GitHub" }
      ],
      "url": site,
      "sameAs": [
        "https://www.linkedin.com/in/adityasharma6/",
        "https://github.com/AdityaSharma6"
      ],
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "McMaster University"
      },
      "knowsAbout": [
        "Software Engineering",
        "AI Engineering",
        "Backend Engineering",
        "Full-Stack Development"
      ],
      "email": "aditya_sharma_@hotmail.com"
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-text font-sans antialiased">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-border">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold text-text hover:text-brand transition-colors">
          Aditya Sharma
        </a>
        <div class="flex items-center gap-6">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "text-sm transition-colors",
                currentPath === link.href
                  ? "text-brand font-medium"
                  : "text-text-muted hover:text-text"
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border mt-16">
      <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <p>&copy; {new Date().getFullYear()} Aditya Sharma. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/in/adityasharma6/" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">LinkedIn</a>
          <a href="https://github.com/AdityaSharma6" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">GitHub</a>
          <a href="mailto:aditya_sharma_@hotmail.com" class="hover:text-text transition-colors">Email</a>
        </div>
      </div>
    </footer>
  </body>
</html>
