---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const currentPath = Astro.url.pathname;
const site = 'https://adityasharma.cc';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/resume/', label: 'Resume' },
  { href: '/experience/', label: 'Experience' },
  { href: '/contact/', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical || `${site}${currentPath}`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${site}${currentPath}`} />
    <meta property="og:site_name" content="Aditya Sharma" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Aditya Sharma",
      "jobTitle": "Software Engineer",
      "worksFor": [
        { "@type": "Organization", "name": "Microsoft" },
        { "@type": "Organization", "name": "GitHub" }
      ],
      "url": site,
      "sameAs": [
        "https://www.linkedin.com/in/adityasharma6/",
        "https://github.com/AdityaSharma6"
      ],
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "McMaster University"
      },
      "knowsAbout": [
        "Software Engineering",
        "AI Engineering",
        "Backend Engineering",
        "Full-Stack Development"
      ],
      "email": "aditya_sharma_@hotmail.com"
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-text font-sans antialiased min-h-screen flex flex-col">
    <!-- Dev Banner -->
    <div class="bg-brand text-white text-center text-xs py-1.5 font-medium tracking-wide">
      🚧 This site is currently in development
    </div>

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-lg border-b border-border-subtle">
      <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-sm font-semibold tracking-tight hover:opacity-70 transition-opacity">
          AS
        </a>
        <div class="flex items-center gap-0.5 sm:gap-1 flex-wrap">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "px-2 sm:px-3 py-1.5 text-xs sm:text-sm rounded-md transition-all",
                currentPath === link.href
                  ? "bg-surface text-text font-medium"
                  : "text-text-muted hover:text-text hover:bg-surface"
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 max-w-3xl mx-auto w-full px-4 sm:px-6 py-10 sm:py-16">
      <slot />
    </main>

    <!-- Calendly badge widget -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
    <script type="text/javascript">
      window.onload = function() {
        Calendly.initBadgeWidget({
          url: 'https://calendly.com/aditya_sharma_/30min',
          text: 'Wanna chat? Let\'s call!',
          color: '#0069ff',
          textColor: '#ffffff',
          branding: false
        });
      }
    </script>

    <!-- Footer -->
    <footer class="border-t border-border-subtle">
      <div class="max-w-3xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-text-faint">
        <p>&copy; {new Date().getFullYear()} Aditya Sharma</p>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/in/adityasharma6/" target="_blank" rel="noopener noreferrer" class="hover:text-text-muted transition-colors">LinkedIn</a>
          <a href="https://github.com/AdityaSharma6" target="_blank" rel="noopener noreferrer" class="hover:text-text-muted transition-colors">GitHub</a>
          <a href="mailto:aditya_sharma_@hotmail.com" class="hover:text-text-muted transition-colors">Email</a>
        </div>
      </div>
    </footer>
  </body>
</html>
