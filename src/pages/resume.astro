---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = "Resume — Aditya Sharma";
const description = "Download or view Aditya Sharma's software engineering resume. Microsoft, GitHub, AI, full-stack.";
---

<BaseLayout title={title} description={description}>
  <section class="animate-in">
    <p class="text-xs font-mono text-text-faint uppercase tracking-widest mb-4">Resume</p>
    <h1 class="text-2xl font-bold mb-2">My Resume</h1>
    <p class="text-sm text-text-muted mb-8">
      View inline or download the PDF.
    </p>

    <div class="flex gap-3 mb-8">
      <a
        href="/AdityaSharma_Resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm px-4 py-2 bg-brand text-white rounded-md hover:bg-brand-dark transition-colors"
      >
        Open PDF ↗
      </a>
      <a
        href="/AdityaSharma_Resume.pdf"
        download
        class="text-sm px-4 py-2 border border-border rounded-md hover:bg-surface transition-colors"
      >
        Download
      </a>
      <a
        href="/experience/"
        class="text-sm px-4 py-2 border border-border rounded-md hover:bg-surface transition-colors"
      >
        Detailed Experience →
      </a>
    </div>

    <!-- Embedded PDF Viewer -->
    <div class="border border-border rounded-lg overflow-hidden">
      <iframe
        src="/AdityaSharma_Resume.pdf"
        class="w-full h-[80vh]"
        title="Aditya Sharma Resume"
      ></iframe>
    </div>

    <p class="mt-4 text-xs text-text-faint">
      Having trouble viewing? <a href="/AdityaSharma_Resume.pdf" target="_blank" rel="noopener noreferrer" class="underline hover:text-text-muted">Open in new tab ↗</a>
    </p>
  </section>
</BaseLayout>
