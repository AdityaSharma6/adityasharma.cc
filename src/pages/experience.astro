---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = "Experience — Aditya Sharma";
const description = "Detailed work experience: Microsoft, GitHub Copilot CLI, SellStatic, McMaster University. Every role, every accomplishment.";

const experience = [
  {
    company: "GitHub",
    role: "Software Engineer, Copilot CLI",
    period: "Jun 2026 – Present",
    location: "Seattle, WA",
    badge: "Dual-Access Employee (Weekends)",
    tech: ["TypeScript", "Rust", "Slack", "GitHub"],
    links: [
      { label: "GitHub Copilot CLI", href: "https://github.com/github/copilot-cli" },
    ],
    bullets: [
      "Selected to contribute open source to GitHub Copilot CLI as a Microsoft Dual-Access Employee",
      "Contributing on weekends to developer tooling used by millions of developers worldwide",
    ],
  },
  {
    company: "Microsoft",
    role: "Software Engineer, AI & Infrastructure",
    period: "Aug 2025 – Present",
    location: "Seattle, WA",
    tech: ["C#", ".NET Core", "ServiceFabric", "Azure", "CosmosDB", "PubSub", "TypeScript", "React", "M365 Agents SDK"],
    links: [
      { label: "M365 Agents SDK", href: "https://github.com/microsoft/agents" },
    ],
    bullets: [
      "Developed an agent eval framework that reduced error diagnosis time by 4x per test, adopted by 5 business teams, caught 3 P0 bugs",
      "Created an internal testing agent running as a standalone validation service with 99.99% uptime",
      "Reduced E2E test runtimes from 8hrs to 1hr, improving productivity for 15 engineers",
      "Authored a 120+ automated-test suite for the distributed systems data Import API; reduced uncaught regressions from 17 to 3",
    ],
  },
  {
    company: "Microsoft",
    role: "Software Engineer, Full-Stack",
    period: "Aug 2022 – Aug 2025",
    location: "Seattle, WA",
    tech: ["C#", ".NET Core", "ServiceFabric", "Azure", "CosmosDB", "PubSub", "TypeScript", "React", "M365 Agents SDK"],
    links: [
      { label: "Microsoft Graph Chat API", href: "https://learn.microsoft.com/en-us/graph/api/resources/chat?view=graph-rest-1.0" },
      { label: "Teams Chat Message API", href: "https://learn.microsoft.com/en-us/graph/api/chatmessage-get?view=graph-rest-1.0" },
      { label: "Teams Push Notifications", href: "https://learn.microsoft.com/en-us/graph/teams-changenotifications-chatmessage" },
    ],
    bullets: [
      "Led front-end engineering for Slack-to-Teams migration: shipped 80% of features, 16M+ messages migrated, 100K+ enterprise tenants, $324M+ ARR pipeline",
      "Built push notification system: <1s latency, 1M+ daily events, 30K+ peak surges, 10K+ monthly developers using public docs",
      "Shipped 4 RESTful Messaging APIs handling 33M+ daily requests each (CodeBlock, ReplyWithQuote, Delta Token V2)",
      "Built Geneva & Grafana monitoring dashboards, identified Sev 2 risks 3 weeks in advance",
    ],
  },
  {
    company: "SellStatic",
    role: "Co-Founder & AI Engineer",
    period: "Dec 2022 – Jan 2026",
    location: "Toronto, ON (Side Venture)",
    tech: ["Python", "React", "TypeScript", "C#", "Flask", "Django", "LangChain", "LangGraph"],
    links: [
      { label: "SellStatic", href: "https://sellstatic.com" },
    ],
    bullets: [
      "Grew to $1K+ MRR, 1.2K-user waitlist, 75 customer interviews, 14-person team, 5 GenAI features shipped",
      "Improved retention by 37%, reduced COGS by 43% with in-house AI media editor",
      "Shipped AI image/video generation across 5 AI models and 5 social platforms with OCR-based evaluation guardrails",
      "Built RAG chatbot: 22% better onboarding, 80% fewer support reachouts (vector search, BM25, RRF fusion, reranking)",
    ],
  },
];

const education = {
  school: "McMaster University",
  degree: "B.Eng in Software & Biomedical Engineering",
  period: "Sep 2018 – May 2022",
  gpa: "3.7 / 4.0",
  details: [
    "42 months additional experience: 28 months SWE internships (Microsoft, Konrad Group, CIBC, Loblaw, Kinaxis) + 14 months as Software Dev, Research Assistant, and Teaching Assistant",
  ],
};

const techStack = {
  "Languages": "Python, C#, Java, TypeScript, JavaScript, Go, C/C++, SQL, HTML/CSS, Bash",
  "Frameworks": "React, .NET Core, Flask, Django, FastAPI, Node.js, Express, LangChain, LangGraph, M365 Agents SDK",
  "Cloud & Infra": "Azure (Functions, DevOps, App Service, Entra, ServiceFabric), AWS, GCP, Docker, Kubernetes",
  "Data": "Cosmos DB, PostgreSQL, Redis, MongoDB, Azure Data Explorer (Kusto/KQL), PubSub",
  "Tools": "Git, CI/CD, Terraform, Grafana, Geneva Monitoring",
};
---

<BaseLayout title={title} description={description}>
  <section class="animate-in">
    <p class="text-xs font-mono text-text-faint uppercase tracking-widest mb-4">Experience</p>
    <h1 class="text-2xl font-bold mb-2">Everything I've built.</h1>
    <p class="text-sm text-text-muted mb-4">Every role, every accomplishment — across my entire career.</p>
    <a
      href="/AdityaSharma_Resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block text-xs text-text-muted underline decoration-border underline-offset-4 hover:decoration-text-muted hover:text-text transition-all"
    >
      Download PDF resume ↗
    </a>
  </section>

  <!-- Work Experience -->
  <div class="mt-14 space-y-14">
    {experience.map((job) => (
      <article class="group">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-1">
          <h2 class="text-base font-semibold">{job.company} <span class="font-normal text-text-muted">— {job.role}</span></h2>
        </div>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
          <p class="text-xs text-text-faint">{job.period} · {job.location}</p>
          {job.badge && (
            <span class="text-[10px] px-2 py-0.5 bg-surface border border-border-subtle rounded-full text-text-muted font-medium">
              {job.badge}
            </span>
          )}
        </div>

        {/* Links to actual work */}
        {job.links && job.links.length > 0 && (
          <div class="flex flex-wrap gap-x-4 gap-y-1 mb-3">
            {job.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-accent hover:text-accent-muted underline underline-offset-2 transition-colors"
              >
                {link.label} ↗
              </a>
            ))}
          </div>
        )}

        <ul class="space-y-2 mb-4">
          {job.bullets.map((b) => (
            <li class="text-sm text-text-muted leading-relaxed pl-4 relative before:content-['–'] before:absolute before:left-0 before:text-text-faint">
              {b}
            </li>
          ))}
        </ul>

        {/* Tech stack tags */}
        <div class="flex flex-wrap gap-1.5">
          {job.tech.map((t) => (
            <span class="text-[10px] px-2 py-0.5 bg-surface border border-border-subtle rounded text-text-faint font-mono">
              {t}
            </span>
          ))}
        </div>
      </article>
    ))}
  </div>

  <!-- Education -->
  <hr class="my-14 border-border-subtle" />
  <section>
    <p class="text-xs font-mono text-text-faint uppercase tracking-widest mb-6">Education</p>
    <article>
      <h2 class="text-base font-semibold">{education.school}</h2>
      <p class="text-sm text-text-muted">{education.degree} · GPA: {education.gpa}</p>
      <p class="text-xs text-text-faint mt-0.5 mb-3">{education.period}</p>
      <ul class="space-y-1.5">
        {education.details.map((d) => (
          <li class="text-sm text-text-muted leading-relaxed pl-4 relative before:content-['–'] before:absolute before:left-0 before:text-text-faint">
            {d}
          </li>
        ))}
      </ul>
    </article>
  </section>

  <!-- Tech Stack -->
  <hr class="my-14 border-border-subtle" />
  <section>
    <p class="text-xs font-mono text-text-faint uppercase tracking-widest mb-6">Technical Skills</p>
    <div class="space-y-4">
      {Object.entries(techStack).map(([category, skills]) => (
        <div>
          <h3 class="text-xs font-semibold text-text uppercase tracking-wide mb-1">{category}</h3>
          <p class="text-sm text-text-muted">{skills}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
