---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = "Experience — Aditya Sharma";
const description = "Detailed work experience with links to shipped work. Microsoft, GitHub Copilot CLI, SellStatic AI.";
---

<BaseLayout title={title} description={description}>
  <section class="animate-in">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Experience</h1>
    <p class="text-sm text-text-muted mb-2">Everything I've built — with links to the actual work.</p>
    <a
      href="/AdityaSharma_Resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-text-faint hover:text-text-muted underline underline-offset-3 transition-colors"
    >
      Download PDF ↗
    </a>
  </section>

  <!-- GitHub -->
  <section class="mt-14">
    <div class="mb-1">
      <h2 class="text-base font-semibold">GitHub</h2>
      <p class="text-sm text-text-muted">Software Engineer, Copilot CLI</p>
      <p class="text-xs text-text-faint mt-0.5">Jun 2026 – Present · Seattle, WA · <span class="italic">Dual-Access Employee (Weekends)</span></p>
    </div>
    <ul class="mt-4 space-y-3">
      <li class="text-[15px] text-text-muted leading-relaxed">
        Selected to contribute open source to 
        <a href="https://github.com/github/copilot-cli" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">GitHub Copilot CLI</a> 
        as a Microsoft Dual-Access Employee. Contributing on weekends.
      </li>
    </ul>
    <div class="mt-3 flex flex-wrap gap-1.5">
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">TypeScript</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">Rust</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">GitHub</span>
    </div>
  </section>

  <hr class="my-10 border-border-subtle" />

  <!-- Microsoft AI & Infra -->
  <section>
    <div class="mb-1">
      <h2 class="text-base font-semibold">Microsoft</h2>
      <p class="text-sm text-text-muted">Software Engineer, AI & Infrastructure</p>
      <p class="text-xs text-text-faint mt-0.5">Aug 2025 – Present · Seattle, WA</p>
    </div>
    <ul class="mt-4 space-y-3">
      <li class="text-[15px] text-text-muted leading-relaxed">
        Developed an <strong class="text-text">agent eval framework</strong> that reduced error diagnosis time by 4x per test, was adopted by 5 business teams to validate agentic communication flows, and caught 3 P0 bugs.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Created an internal <strong class="text-text">testing agent</strong>, running as a standalone validation service with 99.99% uptime and reused by the rest of my team for further validation procedures.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Reduced E2E test runtimes from <strong class="text-text">8hrs to 1hr</strong>, improving productivity for 15 engineers and significantly increasing coding-agent velocity. Accomplished by introducing selective test runs in Azure DevOps CI/CD pipelines.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Authored a 120+ automated-test suite for the distributed systems data 
        <a href="https://learn.microsoft.com/en-us/microsoftteams/platform/graph-api/import-messages/import-external-messages-to-teams" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">Import API</a>; 
        serving as the feature primary validator; reduced uncaught regressions from 17 to 3 across 3 business teams.
      </li>
    </ul>
    <div class="mt-3 flex flex-wrap gap-1.5">
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">C#</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">.NET Core</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">ServiceFabric</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">Azure</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">CosmosDB</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">M365 Agents SDK</span>
    </div>
  </section>

  <hr class="my-10 border-border-subtle" />

  <!-- Microsoft Full-Stack -->
  <section>
    <div class="mb-1">
      <h2 class="text-base font-semibold">Microsoft</h2>
      <p class="text-sm text-text-muted">Software Engineer, Full-Stack</p>
      <p class="text-xs text-text-faint mt-0.5">Aug 2022 – Aug 2025 · Seattle, WA</p>
    </div>
    <ul class="mt-4 space-y-3">
      <li class="text-[15px] text-text-muted leading-relaxed">
        Led front-end engineering for the 
        <a href="https://learn.microsoft.com/en-us/microsoftteams/slack-to-teams-migration-tool" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">Slack-to-Teams migration tool</a>, 
        shipping 80% of features that migrated <strong class="text-text">16M+ messages</strong> across <strong class="text-text">100K+ tenants</strong> and supported a $324M+ ARR migration pipeline.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Engineered 
        <a href="https://learn.microsoft.com/en-us/graph/teams-changenotifications-appinstallation" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">a push notification system</a> 
        sustaining &lt;1sec latency across <strong class="text-text">1M+ daily events</strong> and 30K+ peak surges; public docs serve 10K+ monthly developers, with an 
        <a href="https://github.com/OfficeDev/Microsoft-Teams-Samples/tree/main/samples/sharepoint-tab-request-approval/csharp" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">open-source sample app</a> 
        demonstrating functionality.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Shipped <strong class="text-text">4 RESTful Messaging APIs</strong> handling a minimum of 33M+ daily requests per API, including 
        <a href="https://learn.microsoft.com/en-us/graph/api/chatmessage-post?view=graph-rest-1.0&tabs=http#example-14-send-a-message-with-a-code-block" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">CodeBlock formatting</a>, 
        <a href="https://learn.microsoft.com/en-us/graph/api/chatmessage-replywithquote?view=graph-rest-1.0&tabs=http" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">ReplyWithQuote</a>, and 
        <a href="https://learn.microsoft.com/en-us/graph/api/chatmessage-delta?view=graph-rest-1.0&tabs=http" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">Delta Token V2</a>. 
        Owned schema design, privacy/compliance review, implementation, deployment, and monitoring.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Built Geneva and Grafana monitoring dashboards for distributed APIs, identifying <strong class="text-text">Sev 2 outage risks 3 weeks in advance</strong> and reducing Time To Diagnose to near real-time.
      </li>
    </ul>
    <div class="mt-3 flex flex-wrap gap-1.5">
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">C#</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">.NET Core</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">React</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">TypeScript</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">Azure</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">CosmosDB</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">PubSub</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">ServiceFabric</span>
    </div>
  </section>

  <hr class="my-10 border-border-subtle" />

  <!-- SellStatic -->
  <section>
    <div class="mb-1">
      <h2 class="text-base font-semibold">SellStatic</h2>
      <p class="text-sm text-text-muted">Co-Founder & AI Engineer, Side Venture</p>
      <p class="text-xs text-text-faint mt-0.5">Dec 2022 – Jan 2026 · Toronto, ON</p>
    </div>
    <ul class="mt-4 space-y-3">
      <li class="text-[15px] text-text-muted leading-relaxed">
        Co-founded 
        <a href="https://www.sellstatic.com" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2 hover:text-accent-muted transition-colors">SellStatic</a>, 
        grew it to <strong class="text-text">$1K+ MRR</strong> with a <strong class="text-text">1.2K-user waitlist</strong> via 75 customer interviews, developing and shipping 5 GenAI features while managing a 14-person cross-functional team.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Improved user retention by <strong class="text-text">37%</strong> and reduced COGS by <strong class="text-text">43%</strong> by replacing external API dependencies with an in-house AI-driven media editor.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Shipped AI image and video generation features across 5 third-party AI models and distribution capabilities across 5 social media platforms; designed OCR- and heuristic-based evaluation guardrails to improve output quality before customer rollout.
      </li>
      <li class="text-[15px] text-text-muted leading-relaxed">
        Developed a RAG Customer Support Chatbot that improved onboarding rate by <strong class="text-text">22%</strong> and reduced customer support reachouts by <strong class="text-text">80%</strong> using vector search, BM25, RRF fusion, and reranking.
      </li>
    </ul>
    <div class="mt-3 flex flex-wrap gap-1.5">
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">Python</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">React</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">TypeScript</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">C#</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">Flask</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">Django</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">LangChain</span>
      <span class="text-[11px] px-2 py-0.5 bg-surface border border-border-subtle rounded font-mono text-text-faint">LangGraph</span>
    </div>
  </section>

  <hr class="my-10 border-border-subtle" />

  <!-- Education -->
  <section>
    <div class="mb-1">
      <h2 class="text-base font-semibold">McMaster University</h2>
      <p class="text-sm text-text-muted">B.Eng in Software & Biomedical Engineering · GPA: 3.7/4.0</p>
      <p class="text-xs text-text-faint mt-0.5">Sep 2018 – May 2022</p>
    </div>
    <ul class="mt-4 space-y-3">
      <li class="text-[15px] text-text-muted leading-relaxed">
        <strong class="text-text">42 months</strong> of additional experience: 28 months of SWE internships across Microsoft, Konrad Group, CIBC, Loblaw, and Kinaxis; 14 months as Software Developer, Research Assistant, Databases TA, and Software Requirements TA.
      </li>
    </ul>
  </section>

  <hr class="my-10 border-border-subtle" />

  <!-- Technical Skills -->
  <section>
    <h2 class="text-base font-semibold mb-4">Technical Skills</h2>
    <div class="space-y-3 text-[15px]">
      <div>
        <span class="font-medium text-text">Frameworks & SDKs:</span>
        <span class="text-text-muted"> React, .NET, Flask, Django, FastAPI, Node.js, Express, LangChain, LangGraph</span>
      </div>
      <div>
        <span class="font-medium text-text">Languages:</span>
        <span class="text-text-muted"> Python, C#, Java, TypeScript/JavaScript</span>
      </div>
      <div>
        <span class="font-medium text-text">Cloud & Data:</span>
        <span class="text-text-muted"> Azure, AWS, GCP, Render, MongoDB, CosmosDB, PostgreSQL, SQLite, Redis</span>
      </div>
      <div>
        <span class="font-medium text-text">APIs, AI & Auth:</span>
        <span class="text-text-muted"> Microsoft Graph, Gemini, OpenAI, Claude, VertexAI, Stripe, Auth0/JWT</span>
      </div>
      <div>
        <span class="font-medium text-text">Tools:</span>
        <span class="text-text-muted"> Git, GitHub, Azure DevOps, Grafana, Confluence, Jira, Jupyter</span>
      </div>
    </div>
  </section>
</BaseLayout>
