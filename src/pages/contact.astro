---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = "Contact — Aditya Sharma";
const description = "Get in touch with Aditya Sharma. Software Engineer at Microsoft. Available for opportunities, collaborations, and conversations.";

const contactMethods = [
  {
    label: "Email",
    value: "aditya_sharma_@hotmail.com",
    href: "mailto:aditya_sharma_@hotmail.com",
    primary: true,
    note: "Fastest way to reach me",
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/adityasharma6",
    href: "https://www.linkedin.com/in/adityasharma6/",
  },
  {
    label: "GitHub",
    value: "github.com/AdityaSharma6",
    href: "https://github.com/AdityaSharma6",
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="animate-in max-w-lg">
    <p class="text-xs font-mono text-text-faint uppercase tracking-widest mb-4">Contact</p>
    <h1 class="text-2xl font-bold mb-2">Let's connect.</h1>
    <p class="text-sm text-text-muted mb-10 leading-relaxed">
      Whether you're a recruiter, a founder, or just someone who loves building things — I'd love to hear from you.
    </p>

    <div class="space-y-3">
      {contactMethods.map((method) => (
        <a
          href={method.href}
          target={method.href.startsWith('http') ? '_blank' : undefined}
          rel={method.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class:list={[
            "flex items-center justify-between p-4 rounded-lg border transition-all group",
            method.primary
              ? "border-border bg-surface hover:border-text-faint"
              : "border-border-subtle hover:border-border hover:bg-surface"
          ]}
        >
          <div>
            <p class="text-sm font-medium">{method.label}</p>
            <p class="text-xs text-text-faint">{method.value}</p>
          </div>
          <span class="text-xs text-text-faint group-hover:text-text-muted transition-colors">
            {method.primary ? "Preferred" : "↗"}
          </span>
        </a>
      ))}

      <a
        href="https://calendly.com/aditya_sharma_/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-between p-4 rounded-lg border border-border-subtle hover:border-border hover:bg-surface transition-all group"
      >
        <div>
          <p class="text-sm font-medium">Wanna talk? Book a call!</p>
          <p class="text-xs text-text-faint">30 min via Calendly</p>
        </div>
        <span class="text-xs text-text-faint group-hover:text-text-muted transition-colors">↗</span>
      </a>
    </div>

    <hr class="my-10 border-border-subtle" />

    <div>
      <p class="text-xs font-mono text-text-faint uppercase tracking-widest mb-4">Open to</p>
      <ul class="space-y-1.5">
        <li class="text-sm text-text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-text-faint">Full-time software engineering roles</li>
        <li class="text-sm text-text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-text-faint">AI/ML engineering opportunities</li>
        <li class="text-sm text-text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-text-faint">Startup collaborations & advisory</li>
        <li class="text-sm text-text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-text-faint">Open source contributions</li>
        <li class="text-sm text-text-muted pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-text-faint">Speaking, mentoring, and interesting conversations</li>
      </ul>
    </div>
  </section>
</BaseLayout>
