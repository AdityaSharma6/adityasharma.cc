---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = "Contact — Aditya Sharma";
const description = "Get in touch with Aditya Sharma. Software Engineer at Microsoft, open-source contributor at GitHub. Available for opportunities, collaborations, and conversations.";

const contactMethods = [
  {
    label: "Email",
    value: "aditya_sharma_@hotmail.com",
    href: "mailto:aditya_sharma_@hotmail.com",
    primary: true,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/adityasharma6",
    href: "https://www.linkedin.com/in/adityasharma6/",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "GitHub",
    value: "github.com/AdityaSharma6",
    href: "https://github.com/AdityaSharma6",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="py-8 max-w-xl">
    <h1 class="text-3xl font-bold mb-3">Let's Connect</h1>
    <p class="text-text-muted mb-10 leading-relaxed">
      Whether you're a recruiter, a founder, or just someone who loves building things — I'd love to hear from you. Email is the fastest way to reach me.
    </p>

    <div class="space-y-4">
      {contactMethods.map((method) => (
        <a
          href={method.href}
          target={method.href.startsWith('http') ? '_blank' : undefined}
          rel={method.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class:list={[
            "flex items-center gap-4 p-5 rounded-xl border transition-all",
            method.primary
              ? "border-brand bg-blue-50/50 hover:bg-blue-50"
              : "border-border hover:border-brand/30 hover:bg-surface"
          ]}
        >
          <div class:list={[
            "shrink-0",
            method.primary ? "text-brand" : "text-text-muted"
          ]} set:html={method.icon} />
          <div>
            <p class="text-sm font-medium">{method.label}</p>
            <p class="text-sm text-text-muted">{method.value}</p>
          </div>
          {method.primary && (
            <span class="ml-auto text-xs font-medium text-brand bg-blue-100 px-2 py-0.5 rounded-full">
              Preferred
            </span>
          )}
        </a>
      ))}
    </div>

    <div class="mt-12 p-6 bg-surface rounded-xl border border-border">
      <h2 class="text-base font-semibold mb-2">Open to</h2>
      <ul class="space-y-1.5 text-sm text-text-muted">
        <li>→ Full-time software engineering roles</li>
        <li>→ AI/ML engineering opportunities</li>
        <li>→ Startup collaborations & advisory</li>
        <li>→ Open source contributions</li>
        <li>→ Speaking, mentoring, and interesting conversations</li>
      </ul>
    </div>
  </section>
</BaseLayout>
