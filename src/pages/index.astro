---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = "Aditya Sharma — Software Engineer";
const description = "Software Engineer at Microsoft. Open-source contributor to GitHub Copilot CLI. Ex Co-Founder of SellStatic AI.";
---

<BaseLayout title={title} description={description}>
  <section class="animate-in max-w-xl">
    <h1 class="text-2xl font-semibold tracking-tight mb-6">Hey! I'm Aditya 👋</h1>

    <div class="space-y-4 text-[15px] text-text-muted leading-relaxed">
      <p>
        I'm a Software Engineer at <strong class="text-text">Microsoft</strong> and ex-cofounder of 
        <a href="https://www.sellstatic.com" target="_blank" rel="noopener noreferrer" class="text-text underline decoration-border underline-offset-3 hover:decoration-text-muted transition-colors">SellStatic AI</a>.
        I currently live in Seattle, Washington, but I'm originally from Toronto!
      </p>

      <p>
        At Microsoft, I've worked across backend, frontend, and infrastructure engineering. I'm also an open-source contributor to 
        <a href="https://github.com/github/copilot-cli" target="_blank" rel="noopener noreferrer" class="text-text underline decoration-border underline-offset-3 hover:decoration-text-muted transition-colors">GitHub Copilot CLI</a> 
        as a Dual-Access Employee on weekends. At SellStatic, in addition to wearing every engineering hat a startup requires, I was in a leadership position and led product management efforts.
      </p>

      <p>
        I studied at <strong class="text-text">McMaster University</strong> and obtained a dual major — one in Biomedical Engineering and one in Software Engineering.
      </p>

      <p>
        Outside of work, I try to live my life to the fullest. I enjoy optimizing things like my health, sleep, and fun-time routines. The gym is my escape — I don't try to bodybuild, but for the amount of time I spend in there, one would think I do!
      </p>

      <p>
        I enjoy eating — like, I seriously cannot live without eating. My record for sushi is 72 pieces in one sitting. It would be amiss to say I don't have a sweet tooth either — donuts, brownies, cinnamon rolls, and traditional Indian sweets like barfi, kalakand, and modaks.
      </p>

      <p>
        If anybody would like to chat or try to beat me in a sushi eating competition, feel free to 
        <a href="/contact/" class="text-text underline decoration-border underline-offset-3 hover:decoration-text-muted transition-colors">reach out</a> anytime!
      </p>
    </div>
  </section>

  <hr class="my-14 border-border-subtle" />

  <!-- Quick Links -->
  <section class="animate-in-delay">
    <div class="grid sm:grid-cols-2 gap-3">
      <a href="/experience/" class="group flex items-center justify-between p-4 rounded-lg border border-border-subtle hover:border-border hover:bg-surface transition-all">
        <div>
          <p class="text-sm font-medium">Experience</p>
          <p class="text-xs text-text-faint mt-0.5">My work at Microsoft, GitHub, SellStatic</p>
        </div>
        <span class="text-text-faint group-hover:text-text-muted transition-colors">→</span>
      </a>
      <a href="/resume/" class="group flex items-center justify-between p-4 rounded-lg border border-border-subtle hover:border-border hover:bg-surface transition-all">
        <div>
          <p class="text-sm font-medium">Resume</p>
          <p class="text-xs text-text-faint mt-0.5">Download or view my resume</p>
        </div>
        <span class="text-text-faint group-hover:text-text-muted transition-colors">→</span>
      </a>
      <a href="https://www.linkedin.com/in/adityasharma6/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between p-4 rounded-lg border border-border-subtle hover:border-border hover:bg-surface transition-all">
        <div>
          <p class="text-sm font-medium">LinkedIn</p>
          <p class="text-xs text-text-faint mt-0.5">Connect with me</p>
        </div>
        <span class="text-text-faint group-hover:text-text-muted transition-colors">↗</span>
      </a>
      <a href="https://github.com/AdityaSharma6" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between p-4 rounded-lg border border-border-subtle hover:border-border hover:bg-surface transition-all">
        <div>
          <p class="text-sm font-medium">GitHub</p>
          <p class="text-xs text-text-faint mt-0.5">See my code</p>
        </div>
        <span class="text-text-faint group-hover:text-text-muted transition-colors">↗</span>
      </a>
    </div>
  </section>
</BaseLayout>
